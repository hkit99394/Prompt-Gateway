# Staging environment variable values (copy to staging.tfvars and fill in)
# Usage: terraform plan -var-file=staging.tfvars
# NEVER commit staging.tfvars - it may contain sensitive values

aws_region      = "us-east-1"
environment     = "staging"
certificate_arn = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERT_ID"  # ACM cert for HTTPS
# Optional Lambda cutover:
# enable_lambda_processing = true
# provider_lambda_package_path = "artifacts/provider-worker-lambda.zip"
# result_lambda_package_path = "artifacts/control-plane-result-lambda.zip"
# outbox_lambda_package_path = "artifacts/control-plane-outbox-lambda.zip"
